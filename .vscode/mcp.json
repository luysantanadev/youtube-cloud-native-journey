{
	"servers": {
		"kubernetes": {
			"command": "npx",
			"args": [
				"-y",
				"kubernetes-mcp-server@latest",
				"--disable-multi-cluster",
				"--toolsets",
				"core,config,helm",
				"--log-level",
				"1"
			],
			"type": "stdio"
		},
		"DeepWiki": {
			"url": "https://mcp.deepwiki.com/mcp",
			"type": "http"
		},
		"awesome-copilot": {
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:latest"
			],
			"type": "stdio"
		}
	},
	"inputs": []
}