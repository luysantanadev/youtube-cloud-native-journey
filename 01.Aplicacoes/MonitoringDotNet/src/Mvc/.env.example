# ============================================================
# Ambiente
# ============================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ============================================================
# Observabilidade — endpoints internos do cluster k3d
# ============================================================

# Traces -> Grafana Alloy (OTLP/gRPC) -> Tempo
# localhost:4317 e roteado pelo Traefik IngressRouteTCP ao Alloy dentro do cluster
Observability__ServiceName=monitoring-dotnet-mvc
Observability__ServiceVersion=1.0.0
Observability__Otlp__Endpoint=http://localhost:4317

# Logs -> Loki via HTTP ingress (porta 80); Alloy nao coleta stdout de processos locais
Observability__Loki__Uri=http://loki.monitoramento.local

# Profiling -> Grafana Pyroscope via HTTP ingress (porta 80)
# O native CLR profiler lê estas variáveis antes do código gerenciado iniciar.
# CORECLR_*, LD_* e DOTNET_EnableDiagnostics* já estão fixos na imagem Docker.
PYROSCOPE_APPLICATION_NAME=monitoring-dotnet-mvc
PYROSCOPE_SERVER_ADDRESS=http://pyroscope.monitoramento.local
PYROSCOPE_PROFILING_ENABLED=1
PYROSCOPE_PROFILING_CPU_ENABLED=true
PYROSCOPE_PROFILING_WALLTIME_ENABLED=true
PYROSCOPE_PROFILING_ALLOCATION_ENABLED=true
PYROSCOPE_PROFILING_LOCK_ENABLED=true
PYROSCOPE_PROFILING_EXCEPTION_ENABLED=true
PYROSCOPE_PROFILING_HEAP_ENABLED=true

# ============================================================
# PostgreSQL — dev local (sem TLS)
# ============================================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=monitoring
PG_USER=postgres
PG_PASSWD=postgres

# ============================================================
# Redis — porta padrão; em produção o Vault injeta REDIS_PASSWORD
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=Workshop123redis
