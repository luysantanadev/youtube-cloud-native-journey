@{
    ViewData["Title"] = "Home";
}

<div class="px-4 py-5 text-center">
    <i class="bi bi-thermometer-half display-4 text-primary"></i>
    <h1 class="display-6 fw-bold mt-3">Monitoring .NET MVC</h1>
    <p class="lead text-muted col-lg-6 mx-auto">
        Aplicação MVC com EF Core + PostgreSQL, cache Redis e observabilidade completa
        (traces → Tempo, métricas → Prometheus, logs → Loki).
    </p>
    <a asp-controller="Weather" asp-action="Index" class="btn btn-primary btn-lg mt-2">
        <i class="bi bi-cloud-sun me-1"></i> Ver Registros Climáticos
    </a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
    <div class="col">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-database fs-3 text-success"></i>
                <h5 class="card-title mt-2">PostgreSQL + EF Core</h5>
                <p class="card-text text-muted">
                    Persistência com pool de conexões Npgsql, migrações automáticas e
                    instrumentação OTel de queries SQL.
                </p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-lightning-charge fs-3 text-warning"></i>
                <h5 class="card-title mt-2">Cache Redis</h5>
                <p class="card-text text-muted">
                    Listagem de registros cacheada por 60 s com invalidação automática
                    em Create, Edit e Delete.
                </p>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">
                <i class="bi bi-graph-up fs-3 text-info"></i>
                <h5 class="card-title mt-2">Observabilidade</h5>
                <p class="card-text text-muted">
                    Traces distribuídos via Tempo, métricas no Prometheus/Grafana e logs
                    estruturados JSON no Loki.
                </p>
            </div>
        </div>
    </div>
</div>
