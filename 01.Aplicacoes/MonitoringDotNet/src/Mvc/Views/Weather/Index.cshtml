@model List<WeatherRecord>
@{
    ViewData["Title"] = "Registros Climáticos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-cloud-sun me-2"></i>@ViewData["Title"]</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Novo Registro
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Nenhum registro encontrado.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Data</th>
                    <th>Temperatura (°C)</th>
                    <th>Resumo</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.RecordedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            <span class="badge @(r.TemperatureC >= 30 ? "bg-danger" : r.TemperatureC >= 15 ? "bg-warning text-dark" : "bg-info text-dark")">
                                @r.TemperatureC °C
                            </span>
                        </td>
                        <td>@r.Summary</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@r.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
