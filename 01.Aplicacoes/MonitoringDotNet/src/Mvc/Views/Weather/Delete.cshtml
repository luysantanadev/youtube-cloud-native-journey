@model WeatherRecord
@{
    ViewData["Title"] = "Excluir Registro";
}

<h2 class="mb-4 text-danger"><i class="bi bi-trash me-2"></i>@ViewData["Title"]</h2>

<div class="alert alert-warning">
    Tem certeza que deseja excluir este registro? Esta ação não pode ser desfeita.
</div>

<div class="card shadow-sm border-danger" style="max-width: 480px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Data</dt>
            <dd class="col-sm-8">@Model.RecordedAt.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Temperatura</dt>
            <dd class="col-sm-8">@Model.TemperatureC °C</dd>

            <dt class="col-sm-4">Resumo</dt>
            <dd class="col-sm-8">@Model.Summary</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger btn-sm">
                <i class="bi bi-trash me-1"></i> Confirmar Exclusão
            </button>
        </form>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Cancelar</a>
    </div>
</div>
