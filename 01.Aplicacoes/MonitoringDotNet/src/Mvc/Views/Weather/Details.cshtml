@model WeatherRecord
@{
    ViewData["Title"] = "Detalhes do Registro";
}

<h2 class="mb-4"><i class="bi bi-info-circle me-2"></i>@ViewData["Title"]</h2>

<div class="card shadow-sm" style="max-width: 480px;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">ID</dt>
            <dd class="col-sm-8">@Model.Id</dd>

            <dt class="col-sm-4">Data</dt>
            <dd class="col-sm-8">@Model.RecordedAt.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Temperatura</dt>
            <dd class="col-sm-8">@Model.TemperatureC °C</dd>

            <dt class="col-sm-4">Resumo</dt>
            <dd class="col-sm-8">@Model.Summary</dd>
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-pencil me-1"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Voltar</a>
    </div>
</div>
