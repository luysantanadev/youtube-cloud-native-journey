@model WeatherRecord
@{
    ViewData["Title"] = "Novo Registro";
}

<h2 class="mb-4"><i class="bi bi-plus-circle me-2"></i>@ViewData["Title"]</h2>

<div class="card shadow-sm" style="max-width: 480px;">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

            <div class="mb-3">
                <label asp-for="RecordedAt" class="form-label"></label>
                <input asp-for="RecordedAt" class="form-control" type="date" />
                <span asp-validation-for="RecordedAt" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="TemperatureC" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="TemperatureC" class="form-control" />
                    <span class="input-group-text">°C</span>
                </div>
                <span asp-validation-for="TemperatureC" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Summary" class="form-label"></label>
                <input asp-for="Summary" class="form-control" />
                <span asp-validation-for="Summary" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-floppy me-1"></i> Salvar
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
