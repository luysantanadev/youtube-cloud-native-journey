# Arquivo de exemplo para uso com --env-file no docker run.
# Copie para .env e ajuste os valores antes de usar.
# No Kubernetes, estas variáveis viriam de um ConfigMap (não-sensíveis)
# e de um Secret (sensíveis como DB_PASS).

# Configuração da aplicação
APP_NAME=workshop-app
APP_ENV=homologation
APP_MESSAGE=Carregado via --env-file!
PORT=3000

# Configuração do banco (não-sensível → ConfigMap no Kubernetes)
DB_HOST=postgres-hml:5432
DB_USER=hml_user

# Credencial (sensível → Secret no Kubernetes — nunca commitar o valor real)
DB_PASS=troque_este_valor
