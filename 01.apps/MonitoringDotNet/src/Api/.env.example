# ============================================================
# Ambiente
# ============================================================
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# ============================================================
# Observabilidade — endpoints internos do cluster k3d
# ============================================================

# Traces -> Grafana Tempo (OTLP/gRPC)
Observability__ServiceName=monitoring-dotnet-api
Observability__ServiceVersion=1.0.0
Observability__Otlp__Endpoint=http://tempo:4317

# Logs -> Loki  (coletados pelo Grafana Alloy via stdout do pod)
Observability__Loki__Uri=http://loki:3100

# Profiling -> Grafana Pyroscope
Observability__Pyroscope__ServerAddress=http://pyroscope:4040
Observability__Pyroscope__ApplicationName=monitoring-dotnet-api

# ============================================================
# PostgreSQL — dev local (sem TLS)
# ============================================================
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=monitoring
PG_USER=postgres
PG_PASSWD=postgres

# ============================================================
# Redis — porta padrão; em produção o Vault injeta REDIS_PASSWORD
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
