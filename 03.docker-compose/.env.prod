# Variáveis de produção — carregadas via env_file no compose.yml.
# PORT e APP_ENV são sobrescritos diretamente no compose.yml para deixar
# explícito o que muda entre ambientes sem duplicar todo o arquivo.

APP_NAME=workshop-prod
APP_MESSAGE=Bem-vindo à produção!
DB_HOST=postgres-prod:5432
DB_USER=prod_user
DB_PASS=troque_antes_de_usar
