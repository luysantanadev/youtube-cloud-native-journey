# Variáveis de homologação — carregadas via env_file no compose.yml.
# No Kubernetes este arquivo seria substituído por um ConfigMap (valores não
# sensíveis) e um Secret (DB_PASS), sem alterar a imagem ou o manifest.

APP_NAME=workshop-hml
APP_ENV=homologation
APP_MESSAGE=Ambiente de homologação — validação antes de produção
DB_HOST=postgres-hml:5432
DB_USER=hml_user
DB_PASS=hml_secret
